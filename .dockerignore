# ------------------------------------------------------------------ #
#  .dockerignore — files to exclude from Docker build context          #
# ------------------------------------------------------------------ #

.git
.gitignore
*.md
*.log
*.out
bin/
tests/
# Re-include the bundled demo agent the runtime image needs.
!tests/fake_agent.py
!tests/fake_agent.sh
logs/
.venv/
vendor/unity/
vendor/cjson/*.o
*.o
*.a
.DS_Store
